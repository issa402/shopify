# =============================================================================
# NexusOS 2026 — Environment Variables
# Copy this file to .env and fill in real values
# =============================================================================

# --- Shopify ---
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_APP_URL=http://localhost:8080
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret

# --- AI / LLM ---
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OLLAMA_BASE_URL=http://localhost:11434

# --- Database ---
DATABASE_URL=postgres://nexusos:nexusos_pass@localhost:5432/nexusos?sslmode=disable
POSTGRES_USER=nexusos
POSTGRES_PASSWORD=nexusos_pass
POSTGRES_DB=nexusos

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Qdrant (Vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nexusos_embeddings

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=nexusos-consumers

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=nexusos

# --- MCP Connectors ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
GOOGLE_DRIVE_CREDENTIALS_FILE=./credentials/google-drive.json

# --- App ---
GO_ENV=development
PYTHON_ENV=development
PORT_GATEWAY=8080
PORT_AI=8000
PORT_WEB=3000

# --- Security ---
JWT_SECRET=change_me_to_a_random_64_char_string
ENCRYPTION_KEY=change_me_to_a_random_32_byte_key

# --- PokémonTool Integration ---
# URL of the PokémonTool Go backend (port 3001)
# In Docker: http://pokemon-server:3001  |  Local dev: http://localhost:3001
POKEMONTOOL_API_URL=http://localhost:3001
# Shared secret for internal service-to-service auth (X-Internal-Secret header)
POKEMONTOOL_API_SECRET=change_me_to_a_shared_internal_secret
# NexusOS also accepts webhooks FROM PokémonTool on this path
INTERNAL_SECRET=change_me_to_a_shared_internal_secret
